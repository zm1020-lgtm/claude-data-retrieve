{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "network": {
      "allowedDomains": [
        "api.hyperliquid.xyz",
        "stats-data.hyperliquid.xyz"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(python3 scripts/whale_scanner.py:*)",
      "Bash(pip3 install requests)",
      "Bash(mkdir -p briefings)",
      "Bash(git add briefings/)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  }
}
